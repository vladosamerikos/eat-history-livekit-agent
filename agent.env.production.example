# --- LiveKit (mismos que el backend) ---
LIVEKIT_URL=https://lk.vladys.dev
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Vertex AI ---
GOOGLE_VERTEX_PROJECT=eat-history-ai
GOOGLE_VERTEX_LOCATION=europe-southwest1

# Ruta absoluta al ADC en el HOST (gcloud auth application-default login).
# Por defecto: $HOME/.config/gcloud/application_default_credentials.json
# En el servidor de prod sueles usar /home/ubuntu/.config/gcloud/application_default_credentials.json
#GOOGLE_ADC_PATH=/home/ubuntu/.config/gcloud/application_default_credentials.json

# --- Modelos (opcional, defaults sensatos) ---
# Opciones disponibles en Madrid: gemini-2.5-flash (recomendado por velocidad/coste), gemini-2.5-pro
AGENT_LLM_MODEL=gemini-2.5-flash

# --- Motor de Texto a Voz (TTS) ---
# Opciones: chirp3 (alta calidad), journey (conversacional premium), neural2 (rápido y estándar)
AGENT_TTS_ENGINE=chirp3

# Nivel de log
LOG_LEVEL=INFO
